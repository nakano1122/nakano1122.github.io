---
/**
 * プロジェクト詳細ページ共通レイアウト
 * Research と Development で共有
 */
import Layout from './Layout.astro';
import NavigationModal from '@/components/ui/NavigationModal.astro';
import BackToNav from '@/components/ui/BackToNav.astro';
import type { BilingualText } from '@/types';

export interface Props {
	title: string;
	description: string;
	backLink: {
		href: string;
		labelJa: string;
		labelEn: string;
	};
	label?: BilingualText;
	projectTitle: BilingualText;
	summary?: BilingualText;
	image?: BilingualText;
	period?: {
		startDate: Date;
		endDate?: Date;
	};
	repository?: string;
	links?: string[];
}

const {
	title,
	description,
	backLink,
	label,
	projectTitle,
	summary,
	image,
	period,
	repository,
	links,
} = Astro.props;

const formatPeriod = (startDate: Date, endDate?: Date) => {
	const start = startDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'short' });
	if (!endDate) return `${start} -`;
	const end = endDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'short' });
	return `${start} - ${end}`;
};

const formatPeriodEn = (startDate: Date, endDate?: Date) => {
	const start = startDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
	if (!endDate) return `${start} - Present`;
	const end = endDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
	return `${start} - ${end}`;
};
---

<Layout title={title} description={description}>
	<main class="main">
		<BackToNav href={backLink.href} labelJa={backLink.labelJa} labelEn={backLink.labelEn} position="top" />

		<article class="project-detail">
			<header class="project-header">
				<div class="project-meta">
					{label && (
						<span class="label">
							<span class="lang-ja">{label.ja}</span>
							<span class="lang-en">{label.en || label.ja}</span>
						</span>
					)}
					{period && (
						<span class="period">
							<span class="lang-ja">{formatPeriod(period.startDate, period.endDate)}</span>
							<span class="lang-en">{formatPeriodEn(period.startDate, period.endDate)}</span>
						</span>
					)}
				</div>
				<h1 class="project-title">
					<span class="lang-ja">{projectTitle.ja}</span>
					<span class="lang-en">{projectTitle.en || projectTitle.ja}</span>
				</h1>
				{summary && (
					<p class="project-summary">
						<span class="lang-ja">{summary.ja}</span>
						<span class="lang-en">{summary.en || summary.ja}</span>
					</p>
				)}
			</header>

			{image && (
				<div class="project-image">
					<img class="lang-ja" src={image.ja} alt="" loading="lazy" />
					<img class="lang-en" src={image.en || image.ja} alt="" loading="lazy" />
				</div>
			)}

			<div class="project-content">
				<slot />
			</div>

			{(repository || (links && links.length > 0)) && (
				<div class="project-links">
					{repository && (
						<a
							href={repository}
							target="_blank"
							rel="noopener noreferrer"
							class="link-item"
						>
							<svg class="link-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
								<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
							</svg>
							<span>Repository</span>
						</a>
					)}
					{links && links.map((link) => (
						<a
							href={link}
							target="_blank"
							rel="noopener noreferrer"
							class="link-item"
						>
							<svg class="link-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
								<polyline points="15 3 21 3 21 9" />
								<line x1="10" y1="14" x2="21" y2="3" />
							</svg>
							<span class="lang-ja">関連リンク</span>
							<span class="lang-en">Related Link</span>
						</a>
					))}
				</div>
			)}

			<slot name="extra" />
		</article>

		<BackToNav href={backLink.href} labelJa={backLink.labelJa} labelEn={backLink.labelEn} position="bottom" />
		<NavigationModal />
	</main>
</Layout>

<style>
	.main {
		max-width: 800px;
		margin: 0 auto;
		padding: var(--space-2xl) var(--space-xl) var(--space-4xl);
	}

	.back-nav {
		margin-bottom: var(--space-xl);
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		font-size: 0.9rem;
		color: var(--color-text-muted);
		transition: color var(--transition-base);
	}

	.back-link:hover {
		color: var(--color-text);
	}

	.project-header {
		margin-bottom: var(--space-2xl);
	}

	.project-meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--space-sm);
		margin-bottom: var(--space-md);
	}

	.label {
		font-size: 0.75rem;
		font-weight: 500;
		color: var(--color-text-secondary);
		background: var(--color-accent-soft);
		padding: 0.3em 0.8em;
		border-radius: 4px;
		letter-spacing: 0.02em;
	}

	.period {
		font-size: 0.85rem;
		color: var(--color-text-muted);
	}

	.project-title {
		font-size: 1.75rem;
		font-weight: 700;
		line-height: 1.4;
		margin-bottom: var(--space-md);
		color: var(--color-text);
	}

	.project-summary {
		font-size: 1.05rem;
		color: var(--color-text-secondary);
		line-height: 1.7;
	}

	.project-image {
		margin-bottom: var(--space-2xl);
		border-radius: 8px;
		overflow: hidden;
		background: var(--color-bg-subtle);
	}

	.project-image img {
		width: 100%;
		height: auto;
		display: block;
	}

	.project-content {
		margin-bottom: var(--space-2xl);
		font-size: 1rem;
		line-height: 1.8;
		color: var(--color-text);
	}

	.project-content :global(p) {
		margin-bottom: var(--space-lg);
	}

	.project-content :global(p:last-child) {
		margin-bottom: 0;
	}

	.project-content :global(h2),
	.project-content :global(h3) {
		margin-top: var(--space-2xl);
		margin-bottom: var(--space-md);
		font-weight: 600;
	}

	.project-content :global(ul),
	.project-content :global(ol) {
		margin-bottom: var(--space-lg);
		padding-left: var(--space-xl);
	}

	.project-content :global(li) {
		margin-bottom: var(--space-sm);
	}

	.project-links {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-md);
		padding-top: var(--space-lg);
		border-top: 1px solid var(--color-border);
	}

	.link-item {
		display: inline-flex;
		align-items: center;
		gap: var(--space-sm);
		padding: var(--space-sm) var(--space-md);
		font-size: 0.85rem;
		color: var(--color-text);
		background: var(--color-bg-subtle);
		border: 1px solid var(--color-border);
		border-radius: 6px;
		text-decoration: none;
		transition: border-color var(--transition-base), background var(--transition-base);
	}

	.link-item:hover {
		border-color: var(--color-text-muted);
		background: var(--color-bg-elevated);
	}

	.link-icon {
		width: 18px;
		height: 18px;
		flex-shrink: 0;
	}

	@media (max-width: 768px) {
		.main {
			padding: var(--space-2xl) var(--space-lg) var(--space-3xl);
		}

		.project-title {
			font-size: 1.5rem;
		}
	}
</style>

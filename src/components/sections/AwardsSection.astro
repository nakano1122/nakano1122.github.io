---
/**
 * 受賞セクションコンポーネント
 */
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import SectionHeader from '../ui/SectionHeader.astro';

export interface Props {
	entries: CollectionEntry<'awards'>[];
}

const { entries } = Astro.props;

// 各エントリをレンダリング
const awards = await Promise.all(
	entries.map(async (entry) => {
		const { Content } = await render(entry);
		return { slug: entry.id, Content, ...entry.data };
	})
);
---

<section class="section" id="awards">
	<SectionHeader title="Awards" count={`${awards.length} Awards`} />
	<div class="award-list">
		{awards.map((item) => (
			<div
				class="award-item modal-trigger"
				data-modal-trigger={item.slug}
				role="button"
				tabindex="0"
			>
				<div class="award-content">
					<span class="award-title">
						<span class="lang-ja">{item.title_ja}</span>
						<span class="lang-en">{item.title_en || item.title_ja}</span>
					</span>
					{(item.summary_ja || item.summary_en) && (
						<span class="award-subtitle">
							<span class="lang-ja">{item.summary_ja}</span>
							<span class="lang-en">{item.summary_en || item.summary_ja}</span>
						</span>
					)}
				</div>
				<span class="detail-indicator">
					<span class="lang-ja">詳細を見る →</span>
					<span class="lang-en">View details →</span>
				</span>
			</div>
		))}
	</div>

	{awards.map((item) => (
		<template
			id={`detail-${item.slug}`}
			data-title-ja={item.title_ja}
			data-title-en={item.title_en || item.title_ja}
			data-links={(item.links || []).join('|')}
		>
			<item.Content />
		</template>
	))}
</section>

<style>
	.award-list {
		display: flex;
		flex-direction: column;
	}

	.award-item {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-md);
		padding: var(--space-lg) 0;
		border-bottom: 1px solid var(--color-border);
		transition: color var(--transition-base);
		position: relative;
	}

	.award-item:first-child {
		padding-top: 0;
	}

	.award-item:hover .award-title {
		color: var(--color-text);
	}

	.award-content {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}

	.award-title {
		font-size: 1rem;
		font-weight: 500;
		color: var(--color-text);
		line-height: 1.5;
		transition: color var(--transition-base);
	}

	.award-subtitle {
		font-size: 0.85rem;
		color: var(--color-text-muted);
		line-height: 1.5;
	}

	.award-item:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 4px;
	}

	@media (max-width: 768px) {
		.award-item {
			flex-direction: column;
			align-items: flex-start;
			gap: var(--space-xs);
		}
	}
</style>

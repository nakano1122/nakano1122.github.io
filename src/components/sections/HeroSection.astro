---
/**
 * ヒーローセクションコンポーネント
 */
import type { PersonalData } from '../../functions/dataLoader';
import { Icon } from 'astro-icon/components';

export interface Props {
	profile: PersonalData;
}

const { profile } = Astro.props;

// GitHubのユーザー名を抽出
const githubUsername = profile.github.split('/').pop() || '';

// 日本語ランク表記 → CSS変数名のマッピング
const rankColorMap: Record<string, string> = {
	'灰': 'gray',
	'茶': 'brown',
	'緑': 'green',
	'水': 'cyan',
	'青': 'blue',
	'黄': 'yellow',
	'橙': 'orange',
	'赤': 'red',
};

const getAtcoderRankColor = (rank?: string): string => {
	if (!rank) return 'var(--color-text-secondary)';
	const englishRank = rankColorMap[rank];
	return englishRank ? `var(--atcoder-${englishRank})` : 'var(--color-text-secondary)';
};

const atcoderColor = getAtcoderRankColor(profile.atcoder?.rank);
---

<header class="hero">
	<div class="hero-content">
		{profile.avatar && (
			<img
				src={profile.avatar}
				alt={profile.name}
				class="hero-avatar"
				width="120"
				height="120"
			/>
		)}
		<div class="hero-text">
			<h1 class="hero-name">
				<span class="name-ja">{profile.name}</span>
				<span class="name-en">{profile.nameEn}</span>
			</h1>
			<p class="hero-affiliation">
				{profile.department} / {profile.grade}
			</p>
			<div class="hero-links">
				<span class="link-item">
					<Icon name="mdi:email-outline" class="link-icon" />
					{profile.email.user}@{profile.email.domain}
				</span>
				<a href={profile.github} target="_blank" rel="noopener noreferrer" class="link-item">
					<Icon name="mdi:github" class="link-icon" />
					@{githubUsername}
				</a>
				{profile.atcoder && (
					<a
						href={profile.atcoder.url}
						target="_blank"
						rel="noopener noreferrer"
						class="link-item atcoder-link"
						style={`color: ${atcoderColor};`}
					>
						AtCoder
					</a>
				)}
			</div>
		</div>
	</div>
</header>

<style>
	.hero {
		min-height: 90vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: var(--space-4xl) 0;
	}

	.hero-content {
		display: flex;
		align-items: center;
		gap: var(--space-2xl);
	}

	.hero-avatar {
		width: 120px;
		height: 120px;
		border-radius: 50%;
		object-fit: cover;
		flex-shrink: 0;
	}

	.hero-name {
		font-family: var(--font-display);
		font-size: clamp(2.5rem, 8vw, 4rem);
		font-weight: 700;
		line-height: 1.15;
		margin-bottom: var(--space-lg);
		color: var(--color-text);
	}

	.name-ja {
		display: block;
	}

	.name-en {
		display: block;
		font-size: 0.35em;
		font-weight: 300;
		color: var(--color-text-muted);
		margin-top: var(--space-sm);
		letter-spacing: 0.05em;
	}

	.hero-affiliation {
		font-size: 1rem;
		color: var(--color-text-secondary);
		margin-bottom: var(--space-xl);
		font-weight: 400;
	}

	.hero-links {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-lg);
		align-items: center;
	}

	.link-item {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.9rem;
		color: var(--color-text-secondary);
	}

	a.link-item {
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-color: var(--color-border);
		transition: color var(--transition-base), text-decoration-color var(--transition-base);
	}

	a.link-item:hover {
		color: var(--color-text);
		text-decoration-color: var(--color-text);
	}

	.link-icon {
		width: 16px;
		height: 16px;
		flex-shrink: 0;
	}

	.atcoder-link {
		font-weight: 500;
	}

	@media (max-width: 768px) {
		.hero {
			min-height: auto;
			padding: var(--space-3xl) 0 var(--space-xl);
		}

		.hero-content {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}

		.hero-avatar {
			width: 100px;
			height: 100px;
		}

		.hero-name {
			font-size: clamp(2rem, 10vw, 2.5rem);
		}

		.hero-links {
			gap: var(--space-md);
			justify-content: center;
		}

		.link-item {
			font-size: 0.85rem;
		}
	}
</style>

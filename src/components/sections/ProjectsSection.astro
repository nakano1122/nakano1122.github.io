---
/**
 * プロジェクトセクションコンポーネント
 */
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import SectionHeader from '../ui/SectionHeader.astro';

export interface Props {
	entries: CollectionEntry<'projects'>[];
}

const { entries } = Astro.props;

// 各エントリをレンダリング
const projects = await Promise.all(
	entries.map(async (entry) => {
		const { Content } = await render(entry);
		return { slug: entry.id, Content, ...entry.data };
	})
);
---

{projects.length > 0 && (
	<section class="section" id="projects">
		<SectionHeader title="Projects" />
		<div class="project-list">
			{projects.map((project) => (
				<div
					class="project-item modal-trigger"
					data-modal-trigger={project.slug}
					role="button"
					tabindex="0"
				>
					<div class="project-content">
						<span class="project-name">
							<span class="lang-ja">{project.name_ja}</span>
							<span class="lang-en">{project.name_en || project.name_ja}</span>
						</span>
						<span class="project-title">
							<span class="lang-ja">{project.title_ja}</span>
							<span class="lang-en">{project.title_en || project.title_ja}</span>
						</span>
					</div>
					<span class="detail-indicator">
						<span class="lang-ja">詳細を見る →</span>
						<span class="lang-en">View details →</span>
					</span>
				</div>
			))}
		</div>

		{projects.map((project) => (
			<template
				id={`detail-${project.slug}`}
				data-title-ja={project.name_ja}
				data-title-en={project.name_en || project.name_ja}
				data-presentation=""
				data-award-ja=""
				data-award-en=""
				data-links={(project.links || []).join('|')}
			>
				<project.Content />
			</template>
		))}
	</section>
)}

<style>
	.project-list {
		display: flex;
		flex-direction: column;
	}

	.project-item {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-md);
		padding: var(--space-lg) 0;
		border-bottom: 1px solid var(--color-border);
		transition: color var(--transition-base);
		position: relative;
	}

	.project-item:first-child {
		padding-top: 0;
	}

	.project-item:hover .project-title {
		color: var(--color-text);
	}

	.project-content {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}

	.project-name {
		font-size: 0.8rem;
		font-weight: 500;
		color: var(--color-text-muted);
		line-height: 1.4;
	}

	.project-title {
		font-size: 1rem;
		font-weight: 500;
		color: var(--color-text);
		line-height: 1.5;
		transition: color var(--transition-base);
	}

	.project-item:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 4px;
	}

	@media (max-width: 768px) {
		.project-item {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>

---
/**
 * 経験セクションコンポーネント（インターンシップ・研究室）
 */
import type { PersonalData } from '../../functions/dataLoader';
import { formatPeriod } from '../../functions/dataLoader';
import { Icon } from 'astro-icon/components';
import SectionHeader from '../ui/SectionHeader.astro';

export interface Props {
	jobHistory: PersonalData['jobHistory'];
	laboratories: PersonalData['laboratories'];
}

const { jobHistory, laboratories } = Astro.props;
---

<section class="section" id="experience">
	<SectionHeader title="Experience" />

	<div class="experience-grid">
		<!-- Internships -->
		<div class="experience-column">
			<h3 class="experience-subtitle">Internship</h3>
			<div class="timeline">
				{jobHistory.map((job) => {
					const url = job.hpLink || '';

					return url ? (
						<a
							class="timeline-item timeline-link"
							href={url}
							target="_blank"
							rel="noopener noreferrer"
						>
							<div class="timeline-marker"></div>
							<div class="timeline-content">
								<span class="timeline-period">{formatPeriod(job.startMonth, job.finishMonth)}</span>
								<h4 class="timeline-title">{job.company}</h4>
								<p class="timeline-description">{job.position}</p>
							</div>
							<Icon name="mdi:open-in-new" class="external-icon" />
						</a>
					) : (
						<div class="timeline-item">
							<div class="timeline-marker"></div>
							<div class="timeline-content">
								<span class="timeline-period">{formatPeriod(job.startMonth, job.finishMonth)}</span>
								<h4 class="timeline-title">{job.company}</h4>
								<p class="timeline-description">{job.position}</p>
							</div>
						</div>
					);
				})}
			</div>
		</div>

		<!-- Laboratories -->
		<div class="experience-column">
			<h3 class="experience-subtitle">Laboratory</h3>
			<div class="timeline">
				{laboratories.map((lab) => {
					const url = lab.siteUrl || '';

					return url ? (
						<a
							class="timeline-item timeline-link"
							href={url}
							target="_blank"
							rel="noopener noreferrer"
						>
							<div class="timeline-marker"></div>
							<div class="timeline-content">
								<span class="timeline-period">{formatPeriod(lab.startMonth, lab.finishMonth)}</span>
								<h4 class="timeline-title">{lab.name}</h4>
							</div>
							<Icon name="mdi:open-in-new" class="external-icon" />
						</a>
					) : (
						<div class="timeline-item">
							<div class="timeline-marker"></div>
							<div class="timeline-content">
								<span class="timeline-period">{formatPeriod(lab.startMonth, lab.finishMonth)}</span>
								<h4 class="timeline-title">{lab.name}</h4>
							</div>
						</div>
					);
				})}
			</div>
		</div>
	</div>
</section>

<style>
	.experience-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: var(--space-3xl);
	}

	.experience-subtitle {
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--color-text-muted);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: var(--space-lg);
	}

	/* Timeline */
	.timeline {
		position: relative;
		padding-left: var(--space-xl);
	}

	.timeline::before {
		content: '';
		position: absolute;
		left: 0;
		top: 4px;
		bottom: 4px;
		width: 1px;
		background: var(--color-border);
	}

	.timeline-item {
		position: relative;
		padding-bottom: var(--space-xl);
	}

	.timeline-item:last-child {
		padding-bottom: var(--space-md);
	}

	.timeline-link {
		display: block;
		text-decoration: none;
		color: inherit;
		cursor: pointer;
		padding: var(--space-sm) var(--space-xl) var(--space-sm) var(--space-sm);
		border-radius: 6px;
		transition: background var(--transition-base);
	}

	.timeline-link:hover {
		background: var(--color-accent-soft);
	}

	.timeline-link:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}

	.external-icon {
		position: absolute;
		right: var(--space-sm);
		top: var(--space-sm);
		width: 14px;
		height: 14px;
		color: var(--color-text-muted);
		opacity: 0;
		transition: opacity var(--transition-base);
	}

	.timeline-link:hover .external-icon {
		opacity: 1;
	}

	.timeline-marker {
		position: absolute;
		left: calc(-1 * var(--space-xl));
		top: 8px;
		width: 8px;
		height: 8px;
		background: var(--color-text-muted);
		border-radius: 50%;
		transform: translateX(-3.5px);
	}

	.timeline-period {
		display: block;
		font-size: 0.8rem;
		color: var(--color-text-muted);
		margin-bottom: 2px;
		font-weight: 400;
	}

	.timeline-title {
		font-size: 1rem;
		font-weight: 600;
		margin-bottom: 2px;
		color: var(--color-text);
	}

	.timeline-description {
		font-size: 0.9rem;
		color: var(--color-text-secondary);
	}

	@media (max-width: 768px) {
		.experience-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

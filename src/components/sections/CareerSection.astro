---
/**
 * キャリアセクションコンポーネント
 */
import type { JobHistory } from '@/domain';
import { formatYearMonth } from '@/infrastructure/formatters/date';
import { Icon } from 'astro-icon/components';
import SectionHeader from '@/components/ui/SectionHeader.astro';

export interface Props {
	jobHistory: JobHistory;
}

const { jobHistory } = Astro.props;

function formatPeriod(startDate: Date, endDate?: Date): { ja: string; en: string } {
	const start = formatYearMonth(startDate);
	const endJa = endDate ? formatYearMonth(endDate) : '現在';
	const endEn = endDate ? formatYearMonth(endDate) : 'Present';
	return { ja: `${start} - ${endJa}`, en: `${start} - ${endEn}` };
}
---

<section class="section" id="career">
	<SectionHeader title={{ ja: '経歴', en: 'Career' }} />

	<div class="timeline">
		{jobHistory.entries.map((job) => {
			const url = job.website || '';
			const period = formatPeriod(job.period.startDate, job.period.endDate);

			const className = ['timeline-item', url && 'timeline-link', !job.period.endDate && 'timeline-item--current'].filter(Boolean).join(' ');

			return url ? (
				<a
					class={className}
					href={url}
					target="_blank"
					rel="noopener noreferrer"
				>
					<div class="timeline-content">
						<span class="timeline-period">
							<span class="lang-ja">{period.ja}</span>
							<span class="lang-en">{period.en}</span>
						</span>
						<h4 class="timeline-title">
							<span class="lang-ja">{job.company.ja}</span>
							<span class="lang-en">{job.company.en || job.company.ja}</span>
							<Icon name="mdi:open-in-new" class="external-icon" />
						</h4>
						<p class="timeline-description">
							<span class="lang-ja">{job.position.ja}</span>
							<span class="lang-en">{job.position.en || job.position.ja}</span>
						</p>
					</div>
				</a>
			) : (
				<div class={className}>
					<div class="timeline-content">
						<span class="timeline-period">
							<span class="lang-ja">{period.ja}</span>
							<span class="lang-en">{period.en}</span>
						</span>
						<h4 class="timeline-title">
							<span class="lang-ja">{job.company.ja}</span>
							<span class="lang-en">{job.company.en || job.company.ja}</span>
						</h4>
						<p class="timeline-description">
							<span class="lang-ja">{job.position.ja}</span>
							<span class="lang-en">{job.position.en || job.position.ja}</span>
						</p>
					</div>
				</div>
			);
		})}
	</div>
</section>

<style>
	.timeline {
		display: flex;
		flex-direction: column;
		border-left: 2px solid var(--color-border);
		padding-left: var(--space-xl);
		margin-left: var(--space-sm);
	}

	.timeline-item {
		position: relative;
		padding: var(--space-md) 0;
	}

	.timeline-item::before {
		content: '';
		position: absolute;
		left: calc(-1 * var(--space-xl) - var(--space-sm) - 1px);
		top: calc(var(--space-md) + 6px);
		width: 10px;
		height: 10px;
		background: var(--color-bg);
		border: 2px solid var(--color-text-muted);
		border-radius: 50%;
	}

	.timeline-item--current::before {
		background: var(--color-text);
		border-color: var(--color-text);
	}

	.timeline-link {
		display: block;
		text-decoration: none;
		color: inherit;
		padding: var(--space-md);
		margin-left: calc(-1 * var(--space-md));
		margin-right: calc(-1 * var(--space-md));
		border-radius: 8px;
		transition: background var(--transition-base);
	}

	.timeline-link:hover {
		background: var(--color-accent-soft);
	}

	.timeline-content {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.timeline-period {
		font-size: 0.85rem;
		color: var(--color-text-muted);
		font-weight: 400;
	}

	.timeline-title {
		font-size: 1rem;
		font-weight: 600;
		color: var(--color-text);
		display: flex;
		align-items: center;
		gap: var(--space-xs);
	}

	.external-icon {
		width: 14px;
		height: 14px;
		color: var(--color-text-muted);
		opacity: 0;
		transition: opacity var(--transition-base);
	}

	.timeline-link:hover .external-icon {
		opacity: 1;
	}

	.timeline-description {
		font-size: 0.9rem;
		color: var(--color-text-secondary);
	}
</style>

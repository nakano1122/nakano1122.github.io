---
/**
 * フッターコンポーネント
 */
import type { Profile } from '@/domain';

export interface Props {
	profile: Profile;
}

const { profile } = Astro.props;
const currentYear = new Date().getFullYear();
const name = profile.personalInfo.name.en || profile.personalInfo.name.ja;
---

<footer class="footer">
	<p class="footer-text">&copy; {currentYear} {name}.</p>
</footer>

<style>
	.footer {
		padding: var(--space-2xl) 0;
		text-align: center;
	}

	.footer-text {
		font-size: 0.75rem;
		color: var(--color-text-muted);
	}
</style>

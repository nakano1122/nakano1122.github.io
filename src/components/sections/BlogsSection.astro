---
/**
 * ブログセクションコンポーネント
 * Zenn・Note記事を外部リンクとして表示
 */
import { loadAllBlogArticles } from '@/application';
import type { BlogArticle } from '@/domain';
import { formatYearMonthDay } from '@/infrastructure/formatters/date';
import SectionHeader from '@/components/ui/SectionHeader.astro';

const articles: BlogArticle[] = await loadAllBlogArticles();

const platformIcons: Record<BlogArticle['platform'], string> = {
  zenn: '/icons/zenn.svg',
  note: '/icons/note.svg',
};
---

<section class="section" id="blogs">
  <SectionHeader title={{ ja: 'ブログ', en: 'Blogs' }} />
  <div class="blog-list">
    {articles.map((article) => (
      <a
        class="blog-item"
        href={article.url}
        target="_blank"
        rel="noopener noreferrer"
      >
        <div class="blog-icon" aria-hidden="true">
          <img src={platformIcons[article.platform]} alt="" width="24" height="24" />
        </div>
        <div class="blog-content">
          <span class="blog-title">{article.title}</span>
          <span class="blog-date">{formatYearMonthDay(article.publishedAt)}</span>
        </div>
        <span class="blog-link">
          <span class="lang-ja">記事を読む →</span>
          <span class="lang-en">Read article →</span>
        </span>
      </a>
    ))}
  </div>
</section>

<style>
  .blog-list {
    display: flex;
    flex-direction: column;
  }

  .blog-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--color-border);
    transition: color var(--transition-base);
    position: relative;
    text-decoration: none;
    color: inherit;
  }

  .blog-item:first-child {
    padding-top: 0;
  }

  .blog-item:hover .blog-title {
    color: var(--color-text);
  }

  .blog-item:hover .blog-link {
    color: var(--color-text);
  }

  .blog-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    margin-top: 2px;
  }

  .blog-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .blog-content {
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 2px;
    min-width: 0;
  }

  .blog-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.5;
    transition: color var(--transition-base);
  }

  .blog-date {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .blog-link {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
    transition: color var(--transition-base);
  }

  .blog-item:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  @media (max-width: 768px) {
    .blog-item {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
  }
</style>

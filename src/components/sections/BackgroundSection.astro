---
/**
 * 背景情報セクションコンポーネント（学歴・資格）
 */
import type { PersonalData } from '../../functions/dataLoader';

export interface Props {
	education: PersonalData['education'];
	skills: PersonalData['skills'];
}

const { education, skills } = Astro.props;
---

<section class="section" id="background">
	<div class="info-grid">
		<!-- Education -->
		<div class="info-block">
			<h3 class="info-title">Education</h3>
			<div class="info-list">
				{education.map((edu) => (
					<div class="info-item">
						<span class="info-period">{edu.period}</span>
						<span class="info-label">{edu.institution}</span>
					</div>
				))}
			</div>
		</div>

		<!-- Skills -->
		<div class="info-block">
			<h3 class="info-title">Certifications</h3>
			<div class="info-list">
				{skills.map((skill) => (
					<div class="info-item">
						<span class="info-label">{skill.name}</span>
						{skill.date && <span class="info-period">{skill.date}</span>}
					</div>
				))}
			</div>
		</div>
	</div>
</section>

<style>
	.info-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: var(--space-3xl);
	}

	.info-title {
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--color-text-muted);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: var(--space-lg);
	}

	.info-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
	}

	.info-item {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.info-period {
		font-size: 0.8rem;
		color: var(--color-text-muted);
		font-weight: 400;
	}

	.info-label {
		font-size: 0.95rem;
		color: var(--color-text-secondary);
		font-weight: 400;
	}
</style>

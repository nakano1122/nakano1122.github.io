---
/**
 * 学歴セクションコンポーネント
 */
import type { Education } from '@/domain';
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';
import { formatYearMonth } from '@/infrastructure/formatters/date';
import { Icon } from 'astro-icon/components';
import SectionHeader from '@/components/ui/SectionHeader.astro';

export interface Props {
	entries: { education: Education; Content: AstroComponentFactory }[];
}

const { entries } = Astro.props;

function formatPeriod(startDate: Date, endDate?: Date): { ja: string; en: string } {
	const start = formatYearMonth(startDate);
	const endJa = endDate ? formatYearMonth(endDate) : '現在';
	const endEn = endDate ? formatYearMonth(endDate) : 'Present';
	return { ja: `${start} - ${endJa}`, en: `${start} - ${endEn}` };
}
---

<section class="section" id="education">
	<SectionHeader title={{ ja: '学歴', en: 'Education' }} />

	<div class="timeline">
		{entries.map(({ education: edu }) => {
			const period = formatPeriod(edu.period.startDate, edu.period.endDate);
			const lab = edu.laboratory;
			const url = lab?.website || '';

			return url ? (
				<a
					class="timeline-item timeline-link"
					href={url}
					target="_blank"
					rel="noopener noreferrer"
				>
					<div class="timeline-content">
						<span class="timeline-period">
							<span class="lang-ja">{period.ja}</span>
							<span class="lang-en">{period.en}</span>
						</span>
						<h4 class="timeline-title">
							<span class="lang-ja">{edu.institution.ja}</span>
							<span class="lang-en">{edu.institution.en || edu.institution.ja}</span>
						</h4>
						{lab && (
							<p class="timeline-description">
								<span class="lang-ja">{lab.name.ja}</span>
								<span class="lang-en">{lab.name.en || lab.name.ja}</span>
								<Icon name="mdi:open-in-new" class="external-icon" />
							</p>
						)}
					</div>
				</a>
			) : (
				<div class="timeline-item">
					<div class="timeline-content">
						<span class="timeline-period">
							<span class="lang-ja">{period.ja}</span>
							<span class="lang-en">{period.en}</span>
						</span>
						<h4 class="timeline-title">
							<span class="lang-ja">{edu.institution.ja}</span>
							<span class="lang-en">{edu.institution.en || edu.institution.ja}</span>
						</h4>
						{lab && (
							<p class="timeline-description">
								<span class="lang-ja">{lab.name.ja}</span>
								<span class="lang-en">{lab.name.en || lab.name.ja}</span>
							</p>
						)}
					</div>
				</div>
			);
		})}
	</div>
</section>

<style>
	.timeline {
		display: flex;
		flex-direction: column;
		border-left: 2px solid var(--color-border);
		padding-left: var(--space-xl);
		margin-left: var(--space-sm);
	}

	.timeline-item {
		position: relative;
		padding: var(--space-md) 0;
	}

	.timeline-item::before {
		content: '';
		position: absolute;
		left: calc(-1 * var(--space-xl) - var(--space-sm) - 1px);
		top: calc(var(--space-md) + 6px);
		width: 10px;
		height: 10px;
		background: var(--color-bg);
		border: 2px solid var(--color-text-muted);
		border-radius: 50%;
	}

	.timeline-item:first-child::before {
		background: var(--color-text);
		border-color: var(--color-text);
	}

	.timeline-link {
		display: block;
		text-decoration: none;
		color: inherit;
		padding: var(--space-md);
		margin-left: calc(-1 * var(--space-md));
		margin-right: calc(-1 * var(--space-md));
		border-radius: 8px;
		transition: background var(--transition-base);
	}

	.timeline-link:hover {
		background: var(--color-accent-soft);
	}

	.timeline-content {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.timeline-period {
		font-size: 0.85rem;
		color: var(--color-text-muted);
		font-weight: 400;
	}

	.timeline-title {
		font-size: 1rem;
		font-weight: 600;
		color: var(--color-text);
	}

	.timeline-description {
		font-size: 0.9rem;
		color: var(--color-text-secondary);
		display: inline-flex;
		align-items: center;
		gap: var(--space-xs);
	}

	.external-icon {
		width: 14px;
		height: 14px;
		color: var(--color-text-muted);
		opacity: 0;
		transition: opacity var(--transition-base);
		flex-shrink: 0;
	}

	.timeline-link:hover .external-icon {
		opacity: 1;
	}
</style>

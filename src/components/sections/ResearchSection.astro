---
/**
 * 研究セクションコンポーネント
 */
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import SectionHeader from '../ui/SectionHeader.astro';

export interface Props {
	entries: CollectionEntry<'details'>[];
}

const { entries } = Astro.props;

// 受賞名を「イベント名: 賞名」に分離
function splitAwardName(name: string): { event: string; prize: string } {
	const colonIndex = name.indexOf(':');
	if (colonIndex === -1) return { event: '', prize: name };
	return {
		event: name.substring(0, colonIndex).trim(),
		prize: name.substring(colonIndex + 1).trim(),
	};
}

// 各エントリをレンダリング
const research = await Promise.all(
	entries.map(async (entry) => {
		const { Content } = await render(entry);
		const data = entry.data as {
			title?: string;
			authors?: string;
			conference?: string;
			award?: string;
			links?: string[];
		};
		return { slug: entry.id, Content, ...data };
	})
);
---

<section class="section" id="research">
	<SectionHeader title="Research" count={`${research.length} Publications`} />
	<div class="research-list">
		{research.map((paper, index) => (
			<article
				class="research-item modal-trigger"
				style={`animation-delay: ${index * 100}ms`}
				data-modal-trigger={paper.slug}
				role="button"
				tabindex="0"
			>
				<div class="research-meta">
					<span class="research-conference">{paper.conference}</span>
					{paper.award && (
						<span class="research-award-badge">
							{splitAwardName(paper.award).prize}
						</span>
					)}
				</div>
				<h3 class="research-title">{paper.title}</h3>
				<p class="research-authors">{paper.authors}</p>
				<span class="detail-indicator">詳細を見る →</span>
			</article>
		))}
	</div>

	{/* Template elements for modal content */}
	{research.map((paper) => (
		<template
			id={`detail-${paper.slug}`}
			data-title={paper.title}
			data-presentation={paper.conference || ''}
			data-award={paper.award || ''}
			data-links={(paper.links || []).join('|')}
		>
			<paper.Content />
		</template>
	))}
</section>

<style>
	.section {
		border-top: 1px solid var(--color-border);
	}

	.research-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-xl);
	}

	.research-item {
		padding: var(--space-xl);
		background: var(--color-bg-card);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		transition: all var(--transition-base);
		animation: fadeInUp 0.6s ease-out backwards;
		box-shadow: var(--shadow-sm);
	}

	.research-item:hover {
		border-color: var(--color-border-hover);
		transform: translateY(-3px);
		box-shadow: var(--shadow-md);
	}

	.research-meta {
		margin-bottom: var(--space-md);
	}

	.research-conference {
		display: inline-block;
		padding: var(--space-sm) var(--space-md);
		background: var(--color-highlight-soft);
		color: var(--color-highlight);
		font-size: 0.9rem;
		font-weight: 600;
		border-radius: var(--radius-md);
	}

	.research-award-badge {
		display: inline-block;
		padding: var(--space-sm) var(--space-md);
		background: var(--color-accent-soft);
		color: var(--color-accent);
		font-size: 0.9rem;
		font-weight: 600;
		border-radius: var(--radius-md);
		margin-left: var(--space-sm);
	}

	.research-title {
		font-size: 1.25rem;
		font-weight: 600;
		line-height: 1.6;
		margin-bottom: var(--space-md);
		color: var(--color-text);
	}

	.research-authors {
		font-size: 1rem;
		color: var(--color-text-secondary);
		line-height: 1.7;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>

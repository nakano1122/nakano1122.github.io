---
/**
 * 研究セクションコンポーネント
 */
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import SectionHeader from '../ui/SectionHeader.astro';

export interface Props {
	entries: CollectionEntry<'research'>[];
}

const { entries } = Astro.props;

// 各エントリをレンダリング
const research = await Promise.all(
	entries.map(async (entry) => {
		const { Content } = await render(entry);
		return { slug: entry.id, Content, ...entry.data };
	})
);
---

<section class="section" id="research">
	<SectionHeader title="Research" count={`${research.length} Publications`} />
	<div class="research-list">
		{research.map((paper) => (
			<article
				class="research-item modal-trigger"
				data-modal-trigger={paper.slug}
				role="button"
				tabindex="0"
			>
				<div class="research-meta">
					<span class="research-conference">{paper.conference}</span>
				</div>
				<h3 class="research-title">
					<span class="lang-ja">{paper.title_ja}</span>
					<span class="lang-en">{paper.title_en || paper.title_ja}</span>
				</h3>
				<p class="research-authors">
					<span class="lang-ja">{paper.authors_ja}</span>
					<span class="lang-en">{paper.authors_en || paper.authors_ja}</span>
				</p>
				<span class="detail-indicator">
					<span class="lang-ja">詳細を見る →</span>
					<span class="lang-en">View details →</span>
				</span>
			</article>
		))}
	</div>

	{research.map((paper) => (
		<template
			id={`detail-${paper.slug}`}
			data-title-ja={paper.title_ja}
			data-title-en={paper.title_en || paper.title_ja}
			data-presentation={paper.conference || ''}
			data-award-ja={paper.award_ja || ''}
			data-award-en={paper.award_en || paper.award_ja || ''}
			data-links={(paper.links || []).join('|')}
		>
			<paper.Content />
		</template>
	))}
</section>

<style>
	.research-list {
		display: flex;
		flex-direction: column;
	}

	.research-item {
		padding: var(--space-lg) 0;
		border-bottom: 1px solid var(--color-border);
		transition: color var(--transition-base);
		position: relative;
	}

	.research-item:first-child {
		padding-top: 0;
	}

	.research-item:hover {
		color: var(--color-text-muted);
	}

	.research-item:hover .research-title {
		color: var(--color-text);
	}

	.research-meta {
		display: flex;
		align-items: center;
		gap: var(--space-md);
		margin-bottom: var(--space-sm);
	}

	.research-conference {
		font-size: 0.8rem;
		color: var(--color-text-muted);
		font-weight: 500;
	}

	.research-title {
		font-size: 1.05rem;
		font-weight: 600;
		line-height: 1.6;
		margin-bottom: var(--space-xs);
		color: var(--color-text);
		transition: color var(--transition-base);
	}

	.research-authors {
		font-size: 0.9rem;
		color: var(--color-text-muted);
		line-height: 1.6;
	}
</style>

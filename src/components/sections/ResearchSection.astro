---
/**
 * 研究セクションコンポーネント
 * TOP と /research で共通利用
 */
import type { Research } from '@/domain';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import ProjectCardGrid from '@/components/ui/ProjectCardGrid.astro';

export interface Props {
	entries: Research[];
	showHeader?: boolean;
	actionHref?: string;
}

const { entries, showHeader = true, actionHref } = Astro.props;
---

<section class="section" id="research">
	{showHeader && <SectionHeader title="Research" actionHref={actionHref} />}
	<ProjectCardGrid type="research" items={entries} />
</section>

---
/**
 * Development セクションコンポーネント
 * TOP と /development で共通利用
 */
import type { Development } from '@/domain';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import ProjectCardGrid from '@/components/ui/ProjectCardGrid.astro';

export interface Props {
	entries: Development[];
	showHeader?: boolean;
	actionHref?: string;
}

const { entries, showHeader = true, actionHref } = Astro.props;
---

<section class="section" id="development">
	{showHeader && <SectionHeader title="Development" actionHref={actionHref} />}
	<ProjectCardGrid type="development" items={entries} />
</section>

---
/**
 * Development セクションコンポーネント
 * ハッカソン・開発イベントの成果を表示
 */
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import SectionHeader from '../ui/SectionHeader.astro';

export interface Props {
	entries: CollectionEntry<'development'>[];
}

const { entries } = Astro.props;

// 各エントリをレンダリング
const development = await Promise.all(
	entries.map(async (entry) => {
		const { Content } = await render(entry);
		return { slug: entry.id, Content, ...entry.data };
	})
);
---

<section class="section" id="development">
	<SectionHeader title="Development" count={`${development.length} Projects`} />
	<div class="dev-list">
		{development.map((item) => (
			<div
				class="dev-item modal-trigger"
				data-modal-trigger={item.slug}
				role="button"
				tabindex="0"
			>
				<div class="dev-content">
					<span class="dev-event">
						<span class="lang-ja">{item.name_ja}</span>
						<span class="lang-en">{item.name_en || item.name_ja}</span>
					</span>
					<span class="dev-title">
						<span class="lang-ja">{item.title_ja}</span>
						<span class="lang-en">{item.title_en || item.title_ja}</span>
					</span>
				</div>
				<span class="detail-indicator">
					<span class="lang-ja">詳細を見る →</span>
					<span class="lang-en">View details →</span>
				</span>
			</div>
		))}
	</div>

	{development.map((item) => (
		<template
			id={`detail-${item.slug}`}
			data-title-ja={item.title_ja}
			data-title-en={item.title_en || item.title_ja}
			data-repository={item.repository || ''}
			data-links={(item.links || []).join('|')}
		>
			<item.Content />
		</template>
	))}
</section>

<style>
	.dev-list {
		display: flex;
		flex-direction: column;
	}

	.dev-item {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-md);
		padding: var(--space-lg) 0;
		border-bottom: 1px solid var(--color-border);
		transition: color var(--transition-base);
		position: relative;
	}

	.dev-item:first-child {
		padding-top: 0;
	}

	.dev-item:hover .dev-title {
		color: var(--color-text);
	}

	.dev-content {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}

	.dev-event {
		font-size: 0.8rem;
		font-weight: 500;
		color: var(--color-text-muted);
		line-height: 1.4;
	}

	.dev-title {
		font-size: 1rem;
		font-weight: 500;
		color: var(--color-text);
		line-height: 1.5;
		transition: color var(--transition-base);
	}

	.dev-item:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 4px;
	}

	@media (max-width: 768px) {
		.dev-item {
			flex-direction: column;
			align-items: flex-start;
			gap: var(--space-xs);
		}
	}
</style>

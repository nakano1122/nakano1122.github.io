---
/**
 * 資格セクションコンポーネント
 */
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../../functions/dataLoader';
import SectionHeader from '../ui/SectionHeader.astro';

export interface Props {
	entries: CollectionEntry<'certifications'>[];
}

const { entries } = Astro.props;
---

<section class="section" id="certifications">
	<SectionHeader title="Certifications" />
	<div class="cert-list">
		{entries.map((entry) => (
			<div class="cert-item">
				<span class="cert-date">{formatDate(entry.data.date)}</span>
				<span class="cert-name">{entry.data.name}</span>
			</div>
		))}
	</div>
</section>

<style>
	.cert-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
	}

	.cert-item {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.cert-date {
		font-size: 0.8rem;
		color: var(--color-text-muted);
		font-weight: 400;
	}

	.cert-name {
		font-size: 0.95rem;
		color: var(--color-text-secondary);
		font-weight: 400;
	}
</style>

---
/**
 * 資格セクションコンポーネント
 */
import type { Certification } from '@/domain';
import { formatYearMonth } from '@/domain/infrastructure/formatters/date';
import SectionHeader from '@/components/ui/SectionHeader.astro';

export interface Props {
	entries: Certification[];
}

const { entries } = Astro.props;
---

<section class="section" id="certifications">
	<SectionHeader title="Certifications" />
	<div class="cert-list">
		{entries.map((cert) => (
			<div class="cert-item">
				<span class="cert-date">{formatYearMonth(cert.date)}</span>
				<span class="cert-name">
					<span class="lang-ja">{cert.name.ja}</span>
					<span class="lang-en">{cert.name.en || cert.name.ja}</span>
				</span>
			</div>
		))}
	</div>
</section>

<style>
	.cert-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
	}

	.cert-item {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.cert-date {
		font-size: 0.8rem;
		color: var(--color-text-muted);
		font-weight: 400;
	}

	.cert-name {
		font-size: 0.95rem;
		color: var(--color-text-secondary);
		font-weight: 400;
	}
</style>

---
/**
 * 詳細モーダルコンポーネント
 * <dialog> 要素によるネイティブモーダル実装
 */
import { Icon } from 'astro-icon/components';
---

<dialog id="detail-modal" class="detail-modal">
	<div class="modal-container">
		<header class="modal-header">
			<h2 class="modal-title" id="modal-title"></h2>
			<button class="modal-close" aria-label="閉じる">
				<Icon name="mdi:close" class="modal-close-icon" />
			</button>
		</header>
		<div class="modal-meta" id="modal-meta"></div>
		<div class="modal-body" id="modal-body"></div>
		<footer class="modal-footer" id="modal-footer"></footer>
	</div>
</dialog>

<style is:global>
	/* Modal base */
	.detail-modal {
		max-width: 640px;
		width: calc(100% - var(--space-xl) * 2);
		max-height: 85vh;
		position: fixed;
		inset: 0;
		margin: auto;
		border: none;
		border-radius: 8px;
		background: var(--color-bg-elevated);
		color: var(--color-text);
		padding: 0;
		box-shadow: 0 16px 48px rgba(0, 0, 0, 0.12), 0 4px 16px rgba(0, 0, 0, 0.08);
		overflow: hidden;
	}

	[data-theme='dark'] .detail-modal {
		box-shadow: 0 16px 48px rgba(0, 0, 0, 0.5), 0 4px 16px rgba(0, 0, 0, 0.3);
	}

	.detail-modal::backdrop {
		background: rgba(0, 0, 0, 0.5);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
	}

	/* Open/Close animations */
	.detail-modal[open] {
		animation: modalFadeIn 0.3s ease-out;
	}

	.detail-modal[open]::backdrop {
		animation: backdropFadeIn 0.3s ease-out;
	}

	@keyframes modalFadeIn {
		from {
			opacity: 0;
			transform: translateY(16px) scale(0.98);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	@keyframes backdropFadeIn {
		from { opacity: 0; }
		to { opacity: 1; }
	}

	/* Container */
	.modal-container {
		display: flex;
		flex-direction: column;
		max-height: 85vh;
	}

	/* Header */
	.modal-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: var(--space-md);
		padding: var(--space-xl) var(--space-xl);
		border-bottom: 1px solid var(--color-border);
		flex-shrink: 0;
	}

	.modal-title {
		font-family: var(--font-body);
		font-size: 1.15rem;
		font-weight: 600;
		line-height: 1.5;
		color: var(--color-text);
		flex: 1;
	}

	.modal-close {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		border: none;
		border-radius: 6px;
		background: transparent;
		color: var(--color-text-muted);
		cursor: pointer;
		transition: color var(--transition-fast);
		flex-shrink: 0;
	}

	.modal-close:hover {
		color: var(--color-text);
	}

	.modal-close-icon {
		width: 20px;
		height: 20px;
	}

	/* Meta */
	.modal-meta {
		padding: var(--space-sm) var(--space-xl);
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-md);
		flex-shrink: 0;
	}

	.modal-meta:empty {
		display: none;
	}

	.modal-meta-tag {
		font-size: 0.8rem;
		font-weight: 500;
		color: var(--color-text-muted);
	}

	/* Body */
	.modal-body {
		padding: var(--space-lg) var(--space-xl);
		overflow-y: auto;
		flex: 1;
		min-height: 0;
	}

	/* Markdown content styling */
	.modal-body h2 {
		font-size: 1.05rem;
		font-weight: 600;
		color: var(--color-text);
		margin-top: var(--space-xl);
		margin-bottom: var(--space-sm);
		padding-bottom: var(--space-xs);
		border-bottom: 1px solid var(--color-border);
	}

	.modal-body h2:first-child {
		margin-top: 0;
	}

	.modal-body h3 {
		font-size: 0.95rem;
		font-weight: 600;
		color: var(--color-text);
		margin-top: var(--space-lg);
		margin-bottom: var(--space-xs);
	}

	.modal-body p {
		font-size: 0.9rem;
		color: var(--color-text-secondary);
		line-height: 1.8;
		margin-bottom: var(--space-sm);
	}

	.modal-body ul,
	.modal-body ol {
		padding-left: var(--space-xl);
		margin-bottom: var(--space-sm);
	}

	.modal-body li {
		font-size: 0.9rem;
		color: var(--color-text-secondary);
		line-height: 1.8;
		margin-bottom: 2px;
	}

	.modal-body a {
		color: var(--color-text);
		text-decoration: underline;
		text-underline-offset: 2px;
		text-decoration-color: var(--color-border);
		transition: text-decoration-color var(--transition-fast);
	}

	.modal-body a:hover {
		text-decoration-color: var(--color-text);
	}

	.modal-body blockquote {
		border-left: 2px solid var(--color-border);
		padding-left: var(--space-md);
		margin: var(--space-md) 0;
		color: var(--color-text-muted);
		font-style: italic;
	}

	.modal-body code {
		background: var(--color-bg-subtle);
		padding: 0.1em 0.35em;
		border-radius: 4px;
		font-size: 0.85em;
	}

	.modal-body strong {
		color: var(--color-text);
		font-weight: 600;
	}

	/* Embedded content styling */
	.modal-body iframe {
		width: 100%;
		border: none;
		border-radius: 6px;
		margin: var(--space-md) 0;
	}

	.modal-body img {
		max-width: 100%;
		height: auto;
		border-radius: 6px;
		margin: var(--space-sm) 0;
	}

	/* Footer */
	.modal-footer {
		padding: var(--space-md) var(--space-xl);
		border-top: 1px solid var(--color-border);
		display: flex;
		align-items: center;
		flex-shrink: 0;
	}

	.modal-footer:empty {
		display: none;
	}

	.modal-footer-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-sm);
		flex: 1;
	}

	.modal-repo-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		margin-left: auto;
		padding: var(--space-xs);
		border-radius: 6px;
		color: var(--color-text-muted);
		transition: color var(--transition-base);
	}

	.modal-repo-btn:hover {
		color: var(--color-text);
	}

	.modal-repo-btn img {
		width: 22px;
		height: 22px;
	}

	.modal-link-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		font-size: 0.85rem;
		font-weight: 500;
		color: var(--color-text-secondary);
		text-decoration: underline;
		text-underline-offset: 2px;
		text-decoration-color: var(--color-border);
		transition: color var(--transition-base), text-decoration-color var(--transition-base);
	}

	.modal-link-btn:hover {
		color: var(--color-text);
		text-decoration-color: var(--color-text);
	}

	.modal-link-btn svg {
		width: 14px;
		height: 14px;
		flex-shrink: 0;
	}

	/* Responsive */
	@media (max-width: 768px) {
		.detail-modal {
			width: calc(100% - var(--space-lg) * 2);
			max-height: 90vh;
			border-radius: 8px;
		}

		.modal-container {
			max-height: 90vh;
		}

		.modal-header {
			padding: var(--space-lg) var(--space-lg);
		}

		.modal-title {
			font-size: 1.05rem;
		}

		.modal-meta {
			padding: var(--space-xs) var(--space-lg);
		}

		.modal-body {
			padding: var(--space-md) var(--space-lg);
		}

		.modal-footer {
			padding: var(--space-sm) var(--space-lg);
		}

		.modal-body iframe {
			height: 250px;
		}
	}

	/* Clickable card styles */
	.modal-trigger {
		cursor: pointer;
		position: relative;
	}

	.modal-trigger .detail-indicator {
		position: absolute;
		bottom: var(--space-sm);
		right: 0;
		font-size: 0.8rem;
		font-weight: 400;
		color: var(--color-text-muted);
		opacity: 0;
		transform: translateX(-4px);
		transition: all var(--transition-base);
		pointer-events: none;
	}

	.modal-trigger:hover .detail-indicator,
	.modal-trigger:focus-visible .detail-indicator {
		opacity: 1;
		transform: translateX(0);
	}

	.modal-trigger:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 4px;
	}
</style>

<script>
	function initModal() {
		const dialog = document.getElementById('detail-modal') as HTMLDialogElement;
		if (!dialog) return;

		const titleEl = document.getElementById('modal-title')!;
		const metaEl = document.getElementById('modal-meta')!;
		const bodyEl = document.getElementById('modal-body')!;
		const footerEl = document.getElementById('modal-footer')!;
		const closeBtn = dialog.querySelector('.modal-close')!;

		document.addEventListener('click', (e) => {
			const trigger = (e.target as HTMLElement).closest('[data-modal-trigger]') as HTMLElement;
			if (!trigger) return;
			if ((e.target as HTMLElement).closest('a')) return;

			const slug = trigger.dataset.modalTrigger;
			if (!slug) return;

			const template = document.getElementById(`detail-${slug}`) as HTMLTemplateElement;
			if (!template) return;

			const title = template.dataset.title || '';
			const repository = template.dataset.repository || '';
			const links = template.dataset.links || '';

			titleEl.textContent = title;

			metaEl.innerHTML = '';

			const content = template.content.cloneNode(true);
			bodyEl.innerHTML = '';
			bodyEl.appendChild(content);

			footerEl.innerHTML = '';
			const linksContainer = document.createElement('div');
			linksContainer.className = 'modal-footer-links';
			if (links) {
				links.split('|').forEach((url) => {
					const trimmed = url.trim();
					if (!trimmed) return;
					const a = document.createElement('a');
					a.href = trimmed;
					a.target = '_blank';
					a.rel = 'noopener noreferrer';
					a.className = 'modal-link-btn';
					a.innerHTML = `<span>外部リンク</span><img src="/icons/external-link.svg" alt="" width="14" height="14" />`;
					linksContainer.appendChild(a);
				});
			}
			footerEl.appendChild(linksContainer);
			if (repository) {
				const a = document.createElement('a');
				a.href = repository;
				a.target = '_blank';
				a.rel = 'noopener noreferrer';
				a.className = 'modal-repo-btn';
				a.setAttribute('aria-label', 'GitHub Repository');
				a.innerHTML = `<img src="/icons/github.svg" alt="GitHub" width="22" height="22" />`;
				footerEl.appendChild(a);
			}

			bodyEl.querySelectorAll('iframe').forEach((iframe) => {
				iframe.setAttribute('loading', 'lazy');
			});
			bodyEl.querySelectorAll('img').forEach((img) => {
				img.setAttribute('loading', 'lazy');
			});

			document.body.style.overflow = 'hidden';
			dialog.showModal();
			bodyEl.scrollTop = 0;
		});

		document.addEventListener('keydown', (e) => {
			if (e.key !== 'Enter' && e.key !== ' ') return;
			const trigger = (e.target as HTMLElement).closest('[data-modal-trigger]');
			if (!trigger) return;
			e.preventDefault();
			trigger.dispatchEvent(new MouseEvent('click', { bubbles: true }));
		});

		closeBtn.addEventListener('click', () => {
			dialog.close();
		});

		dialog.addEventListener('click', (e) => {
			if (e.target === dialog) {
				dialog.close();
			}
		});

		dialog.addEventListener('close', () => {
			document.body.style.overflow = '';
		});
	}

	document.addEventListener('DOMContentLoaded', initModal);
	document.addEventListener('astro:after-swap', initModal);
</script>

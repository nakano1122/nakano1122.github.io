---
/**
 * セクションヘッダーコンポーネント
 */
export interface Props {
	title: string | { ja: string; en?: string };
	actionHref?: string;
	actionLabelJa?: string;
	actionLabelEn?: string;
}

const { title, actionHref, actionLabelJa = 'すべて見る', actionLabelEn = 'View all' } = Astro.props;
const titleJa = typeof title === 'string' ? title : title.ja;
const titleEn = typeof title === 'string' ? title : title.en || title.ja;
---

<div class="section-header">
	<h2 class="section-title">
		<span class="lang-ja">{titleJa}</span>
		<span class="lang-en">{titleEn}</span>
	</h2>
	{actionHref && (
		<a class="section-action" href={actionHref}>
			<span class="lang-ja">{actionLabelJa}</span>
			<span class="lang-en">{actionLabelEn}</span>
			<span aria-hidden="true">→</span>
		</a>
	)}
</div>

<style>
	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: var(--space-md);
		margin-bottom: var(--space-lg);
		padding-bottom: var(--space-sm);
		border-bottom: 1px solid var(--color-border);
	}

	.section-title {
		font-family: var(--font-display);
		font-size: 1.25rem;
		font-weight: 600;
		color: var(--color-text);
		min-width: 0;
	}

	.section-action {
		display: inline-flex;
		align-items: center;
		gap: var(--space-xs);
		flex-shrink: 0;
		font-size: 0.85rem;
		font-weight: 500;
		color: var(--color-text-secondary);
		text-decoration: none;
		transition: color var(--transition-base);
	}

	.section-action:hover {
		color: var(--color-text);
	}

	.section-action:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 4px;
	}

	@media (max-width: 768px) {
		.section-header {
			align-items: flex-end;
			gap: var(--space-xs);
		}

		.section-title {
			font-size: 1.5rem;
		}
	}
</style>

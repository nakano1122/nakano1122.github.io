---
/**
 * テーマ切り替えボタンコンポーネント
 */
import { Icon } from 'astro-icon/components';
---

<button
	class="theme-toggle"
	type="button"
	aria-label="テーマを切り替える"
	title="テーマを切り替える"
>
	<Icon name="mdi:weather-sunny" class="toggle-icon sun-icon" />
	<Icon name="mdi:weather-night" class="toggle-icon moon-icon" />
</button>

<script>
	import { initTheme, toggleTheme } from '../../hooks/useTheme';

	function setupThemeToggle() {
		const toggle = document.querySelector('.theme-toggle');
		if (!toggle) return;

		initTheme();
		toggle.addEventListener('click', toggleTheme);
	}

	setupThemeToggle();
	document.addEventListener('astro:after-swap', setupThemeToggle);
</script>

<style>
	.theme-toggle {
		position: relative;
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: transparent;
		border: none;
		border-radius: 8px;
		cursor: pointer;
		color: var(--color-text-muted);
		transition: color var(--transition-base);
	}

	.theme-toggle:hover {
		color: var(--color-text);
	}

	.toggle-icon {
		width: 20px;
		height: 20px;
		position: absolute;
		transition: opacity var(--transition-fast), transform var(--transition-fast);
	}

	/* ライトモード: 月アイコンを表示（クリックでダークへ） */
	.sun-icon {
		opacity: 0;
		transform: rotate(-90deg) scale(0.5);
	}

	.moon-icon {
		opacity: 1;
		transform: rotate(0) scale(1);
	}

	/* ダークモード: 太陽アイコンを表示（クリックでライトへ） */
	:global([data-theme='dark']) .sun-icon {
		opacity: 1;
		transform: rotate(0) scale(1);
	}

	:global([data-theme='dark']) .moon-icon {
		opacity: 0;
		transform: rotate(90deg) scale(0.5);
	}

</style>

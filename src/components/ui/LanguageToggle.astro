---
/**
 * 同一ページの別ロケールへ移動する言語切り替えリンク
 */
import { localizePath, type Locale } from '@/i18n/routing';

export interface Props {
	locale?: Locale;
	alternateHref?: string;
}

const { locale = 'ja', alternateHref } = Astro.props;
const targetLocale: Locale = locale === 'ja' ? 'en' : 'ja';
const href = alternateHref ?? localizePath(targetLocale, Astro.url.pathname);
const label = locale === 'ja' ? 'EN: Switch to English' : 'JA: 日本語に切り替える';
const title = locale === 'ja' ? 'English' : '日本語';
---

<a
	class="lang-toggle"
	href={href}
	aria-label={label}
	title={title}
>
	{locale === 'ja' ? 'EN' : 'JA'}
</a>

<script>
	function setupLanguageToggle() {
		document.querySelectorAll<HTMLAnchorElement>('.lang-toggle:not([data-url-preserved])').forEach((toggle) => {
			const target = new URL(toggle.href, window.location.origin);
			target.search = window.location.search;
			target.hash = window.location.hash;
			toggle.href = target.toString();
			toggle.dataset.urlPreserved = 'true';
		});
	}

	setupLanguageToggle();
	document.addEventListener('astro:after-swap', setupLanguageToggle);
</script>

<style>
	.lang-toggle {
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: transparent;
		border-radius: 8px;
		color: var(--color-text-muted);
		text-decoration: none;
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		transition: color var(--transition-base);
	}

	.lang-toggle:hover {
		color: var(--color-text);
	}

	.lang-toggle:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 3px;
	}
</style>

---
import Layout from '@/components/layouts/Layout.astro';
import { loadCertifications, loadJobHistory, loadEducationWithContent, loadAwards } from '@/application';
import CareerSection from '@/components/sections/CareerSection.astro';
import EducationSection from '@/components/sections/EducationSection.astro';
import AwardsListSection from '@/components/sections/AwardsListSection.astro';
import CertificationsSection from '@/components/sections/CertificationsSection.astro';
import ActivitySection from '@/components/sections/ActivitySection.astro';
import NavigationModal from '@/components/ui/NavigationModal.astro';
import BackToNav from '@/components/ui/BackToNav.astro';

const certificationEntries = await loadCertifications();
const jobHistory = await loadJobHistory();
const educationEntries = await loadEducationWithContent();
const awards = await loadAwards();
---

<Layout title="About | 中野暁登" description="中野暁登のプロフィール - 経歴・学歴・資格">
	<main class="main">
		<BackToNav href="/" labelJa="TOP に戻る" labelEn="Back to TOP" position="top" />

		<header class="page-header">
			<h1 class="page-title">About</h1>
			<p class="intro">
				<span class="lang-ja">愛知県出身の大学院生です。情報検索の研究をしながら、ソフトウェアエンジニアとしても活動しています。</span>
				<span class="lang-en">A graduate student from Aichi, Japan. I research information retrieval while working as a software engineer.</span>
			</p>
		</header>

		<div class="content">
			<CareerSection jobHistory={jobHistory} />
			<EducationSection entries={educationEntries} />
			<AwardsListSection awards={awards} />
			<CertificationsSection entries={certificationEntries} />
			<ActivitySection />
		</div>

		<BackToNav href="/" labelJa="TOP に戻る" labelEn="Back to TOP" position="bottom" />
		<NavigationModal />
	</main>
</Layout>

<style>
	.main {
		max-width: 800px;
		margin: 0 auto;
		padding: 0 var(--space-xl);
	}

	.page-header {
		padding: var(--space-xl) 0 var(--space-2xl);
	}

	.page-title {
		font-size: 2rem;
		font-weight: 700;
		color: var(--color-text);
		margin-bottom: var(--space-lg);
	}

	.intro {
		font-size: 1.1rem;
		color: var(--color-text-secondary);
		line-height: 1.8;
		letter-spacing: 0.02em;
	}

	@media (max-width: 768px) {
		.main {
			padding: 0 var(--space-lg);
		}

		.page-title {
			font-size: 1.75rem;
		}
	}
</style>

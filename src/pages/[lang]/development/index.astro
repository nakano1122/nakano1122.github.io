---
import Layout from '@/components/layouts/Layout.astro';
import NavigationModal from '@/components/ui/NavigationModal.astro';
import ProjectCardGrid from '@/components/ui/ProjectCardGrid.astro';
import AwardsListSection from '@/components/sections/AwardsListSection.astro';
import { loadDevelopment, loadAwardsByCategory } from '@/application';
import { alternateLocalePath, isLocale, locales, localizePath } from '@/i18n/routing';

export function getStaticPaths() {
	return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang;
if (!isLocale(locale)) {
	return Astro.redirect('/ja/development', 302);
}

const developmentEntries = await loadDevelopment();
const developmentAwards = await loadAwardsByCategory('development');
---

<Layout
	locale={locale}
	alternateHref={alternateLocalePath(locale, Astro.url.pathname)}
	title={locale === 'en' ? 'Development | Akito Nakano' : '開発経験 | 中野暁登'}
	titleJa="開発経験 | 中野暁登"
	titleEn="Development | Akito Nakano"
	description={locale === 'en' ? 'Software development experience from personal projects and hackathons, alongside research activities.' : '研究活動と並行して、個人開発・ハッカソンで培ったソフトウェア開発の経験を紹介します。'}
	descriptionJa="研究活動と並行して、個人開発・ハッカソンで培ったソフトウェア開発の経験を紹介します。"
descriptionEn="Software development experience from personal projects and hackathons, alongside research activities."
	headerMaxWidth="900px"
	backLink={{
		href: localizePath(locale),
		labelJa: 'TOP に戻る',
		labelEn: 'Back to TOP',
	}}
>
	<main class="main">
		<header class="page-header">
			<h1 class="page-title"><span class="lang-ja">開発経験</span><span class="lang-en">Development</span></h1>
			<p class="intro">
				<span class="lang-ja">研究活動とともに、個人開発とハッカソンを通じて積み重ねた実践的な開発経験です。</span>
				<span class="lang-en">Practical software development experience built through personal projects and hackathons, alongside my research activities.</span>
			</p>
		</header>
		<div class="projects">
			<ProjectCardGrid type="development" items={developmentEntries} locale={locale} />
		</div>

		{developmentAwards.length > 0 && (
			<AwardsListSection awards={developmentAwards} />
		)}

		<NavigationModal locale={locale} />
	</main>
</Layout>

<style>
	.main {
		max-width: 900px;
		margin: 0 auto;
		padding: 0 var(--space-xl);
	}

	.page-title {
		font-size: 2rem;
		font-weight: 700;
		margin-bottom: var(--space-md);
	}

	.page-header {
		margin-bottom: var(--space-2xl);
	}

	.intro {
		color: var(--color-text-secondary);
		line-height: 1.8;
		letter-spacing: 0.02em;
	}

	.projects {
		margin-bottom: var(--space-2xl);
	}

	@media (max-width: 768px) {
		.main {
			padding: 0 var(--space-lg);
		}

		.page-title {
			font-size: 1.75rem;
		}
	}
</style>

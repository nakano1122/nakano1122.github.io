---
import ProjectDetailLayout from '@/components/layouts/ProjectDetailLayout.astro';
import { loadDevelopment, loadDevelopmentById } from '@/application';
import { alternateLocalePath, isLocale, locales, localizePath } from '@/i18n/routing';

export async function getStaticPaths() {
	const developments = await loadDevelopment();
	return locales.flatMap((lang) => developments.map((development) => ({
		params: { lang, id: development.id },
	})));
}

const locale = Astro.params.lang;
const { id } = Astro.params;
if (!isLocale(locale)) {
	return Astro.redirect('/ja/development', 302);
}

const result = await loadDevelopmentById(id);
if (!result) {
	return Astro.redirect(localizePath(locale, '/development'), 302);
}

const { development, Content } = result;
const title = {
	ja: `${development.title.ja} | й–ӢзҷәзөҢйЁ“ | дёӯйҮҺжҡҒзҷ»`,
	en: `${development.title.en || development.title.ja} | Development | Akito Nakano`,
};
const description = {
	ja: `дёӯйҮҺжҡҒзҷ»гҒ®й–ӢзҷәзөҢйЁ“гҖҢ${development.title.ja}гҖҚгҒ®и©ізҙ°гҒ§гҒҷгҖӮ`,
	en: `Software development experience by Akito Nakano: "${development.title.en || development.title.ja}".`,
};
---

<ProjectDetailLayout
	locale={locale}
	alternateHref={alternateLocalePath(locale, Astro.url.pathname)}
	title={title}
	description={description}
	backLink={{
		href: localizePath(locale, '/development'),
		labelJa: 'Development гҒ«жҲ»гӮӢ',
		labelEn: 'Back to Development',
	}}
	label={development.name}
	projectTitle={development.title}
	image={development.image}
	period={development.period}
	repository={development.repository}
	links={development.links}
>
	<Content />
</ProjectDetailLayout>

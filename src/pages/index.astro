---
import Layout from '@/components/layouts/Layout.astro';
import {
	loadProfile,
	loadJobHistory,
	loadResearchWithContent,
	loadDevelopmentWithContent,
	loadAwardsWithContent,
	loadEducationWithContent,
	loadCertifications,
} from '@/domain';

// Sections
import HeroSection from '@/components/sections/HeroSection.astro';
import ResearchSection from '@/components/sections/ResearchSection.astro';
import DevelopmentSection from '@/components/sections/DevelopmentSection.astro';
import AwardsSection from '@/components/sections/AwardsSection.astro';
import BlogsSection from '@/components/sections/BlogsSection.astro';
import ExperienceSection from '@/components/sections/ExperienceSection.astro';
import CertificationsSection from '@/components/sections/CertificationsSection.astro';
import Footer from '@/components/sections/Footer.astro';
import DetailModal from '@/components/ui/DetailModal.astro';

const profile = await loadProfile();
const jobHistory = await loadJobHistory();
const researchEntries = await loadResearchWithContent();
const developmentEntries = await loadDevelopmentWithContent();
const awardEntries = await loadAwardsWithContent();
const educationEntries = await loadEducationWithContent();
const certificationEntries = await loadCertifications();
---

<Layout title={profile.seo.title} description={profile.seo.description} keywords={profile.seo.keywords}>
	<main class="main">
		<HeroSection profile={profile} />

		<div class="content">
			<ResearchSection entries={researchEntries} />
			<DevelopmentSection entries={developmentEntries} />
			<BlogsSection />
			<AwardsSection entries={awardEntries} />
			<ExperienceSection
				jobHistory={jobHistory}
				education={educationEntries}
			/>
			<CertificationsSection entries={certificationEntries} />
		</div>

		<Footer profile={profile} />
	</main>

	<DetailModal />
</Layout>

<style>
	.main {
		max-width: 800px;
		margin: 0 auto;
		padding: 0 var(--space-xl);
	}

	.content {
		padding-bottom: var(--space-4xl);
	}

	@media (max-width: 768px) {
		.main {
			padding: 0 var(--space-lg);
		}
	}
</style>

---
import Layout from '../layouts/Layout.astro';
import {
	loadPersonalData,
	loadResearch,
	loadDevelopment,
	loadAwards,
	loadEducation,
	loadCertifications,
} from '../functions/dataLoader';
import { loadZennArticles } from '../functions/zennApi';

// Sections
import HeroSection from '../components/sections/HeroSection.astro';
import ResearchSection from '../components/sections/ResearchSection.astro';
import DevelopmentSection from '../components/sections/DevelopmentSection.astro';
import AwardsSection from '../components/sections/AwardsSection.astro';
import BlogsSection from '../components/sections/BlogsSection.astro';
import ExperienceSection from '../components/sections/ExperienceSection.astro';
import CertificationsSection from '../components/sections/CertificationsSection.astro';
import Footer from '../components/sections/Footer.astro';
import DetailModal from '../components/ui/DetailModal.astro';

const personalData = await loadPersonalData();
const researchEntries = await loadResearch();
const developmentEntries = await loadDevelopment();
const awardEntries = await loadAwards();
const zennArticles = await loadZennArticles();
const educationEntries = await loadEducation();
const certificationEntries = await loadCertifications();
---

<Layout title={personalData.title} description={personalData.description} keywords={personalData.keywords}>
	<main class="main">
		<HeroSection profile={personalData} />

		<div class="content">
			<ResearchSection entries={researchEntries} />
			<DevelopmentSection entries={developmentEntries} />
			<BlogsSection articles={zennArticles} />
			<AwardsSection entries={awardEntries} />
			<ExperienceSection
				jobHistory={personalData.jobHistory}
				education={educationEntries}
			/>
			<CertificationsSection entries={certificationEntries} />
		</div>

		<Footer />
	</main>

	<DetailModal />
</Layout>

<style>
	.main {
		max-width: 800px;
		margin: 0 auto;
		padding: 0 var(--space-xl);
	}

	.content {
		padding-bottom: var(--space-4xl);
	}

	@media (max-width: 768px) {
		.main {
			padding: 0 var(--space-lg);
		}
	}
</style>

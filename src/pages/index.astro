---
import Layout from '@/components/layouts/Layout.astro';
import {
	loadProfile,
	loadResearch,
	loadDevelopment,
	loadAwards,
} from '@/application';

// Sections
import HeroSection from '@/components/sections/HeroSection.astro';
import ResearchSection from '@/components/sections/ResearchSection.astro';
import DevelopmentSection from '@/components/sections/DevelopmentSection.astro';
import AwardsListSection from '@/components/sections/AwardsListSection.astro';
import ActivitySection from '@/components/sections/ActivitySection.astro';
import NavigationModal from '@/components/ui/NavigationModal.astro';
import Footer from '@/components/sections/Footer.astro';

const profile = await loadProfile();
const researchEntries = await loadResearch();
const developmentEntries = await loadDevelopment();
const awards = await loadAwards();
---

<Layout title={profile.seo.title} description={profile.seo.description} keywords={profile.seo.keywords}>
	<main class="main">
		<HeroSection profile={profile} />

		<div class="content">
			<ResearchSection entries={researchEntries} />
			<DevelopmentSection entries={developmentEntries} />
			<AwardsListSection awards={awards} />
			<ActivitySection />
			<NavigationModal />
		</div>

		<Footer profile={profile} />
	</main>
</Layout>

<style>
	.main {
		max-width: 880px;
		margin: 0 auto;
		padding: 0 var(--space-xl);
	}

	.content {
		padding-bottom: var(--space-4xl);
	}

	@media (max-width: 768px) {
		.main {
			padding: 0 var(--space-lg);
		}
	}
</style>

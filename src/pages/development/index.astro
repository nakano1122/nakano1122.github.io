---
/**
 * 開発一覧ページ
 * 開発プロジェクトをカード形式で表示
 */
import Layout from '@/components/layouts/Layout.astro';
import NavigationModal from '@/components/ui/NavigationModal.astro';
import ProjectCardGrid from '@/components/ui/ProjectCardGrid.astro';
import AwardsListSection from '@/components/sections/AwardsListSection.astro';
import BackToNav from '@/components/ui/BackToNav.astro';
import { loadDevelopment, loadAwardsByCategory } from '@/application';

const developmentEntries = await loadDevelopment();
const developmentAwards = await loadAwardsByCategory('development');
---

<Layout title="Development | Akito Nakano" description="ハッカソンや個人開発で取り組んだプロジェクトの一覧です。">
	<main class="main">
		<BackToNav href="/" labelJa="TOP に戻る" labelEn="Back to TOP" position="top" />

		<h1 class="page-title">Development</h1>

		<section class="section">
			<h2 class="section-title">Projects</h2>
			<ProjectCardGrid type="development" items={developmentEntries} />
		</section>

		{developmentAwards.length > 0 && (
			<AwardsListSection awards={developmentAwards} />
		)}

		<BackToNav href="/" labelJa="TOP に戻る" labelEn="Back to TOP" position="bottom" />
		<NavigationModal />
	</main>
</Layout>

<style>
	.main {
		max-width: 900px;
		margin: 0 auto;
		padding: 0 var(--space-xl);
	}

	.page-title {
		font-size: 2rem;
		font-weight: 700;
		margin-bottom: var(--space-2xl);
	}

	.section {
		margin-bottom: var(--space-2xl);
	}

	.section-title {
		font-size: 1.1rem;
		font-weight: 600;
		color: var(--color-text-muted);
		margin-bottom: var(--space-lg);
	}

	@media (max-width: 768px) {
		.main {
			padding: 0 var(--space-lg);
		}

		.page-title {
			font-size: 1.75rem;
		}
	}
</style>

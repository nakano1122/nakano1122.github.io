---
/**
 * 研究一覧ページ
 * 研究テーマをカード形式で表示
 */
import Layout from '@/components/layouts/Layout.astro';
import NavigationModal from '@/components/ui/NavigationModal.astro';
import ProjectCardGrid from '@/components/ui/ProjectCardGrid.astro';
import BackToNav from '@/components/ui/BackToNav.astro';
import { loadResearch } from '@/application';

const researchEntries = await loadResearch();
---

<Layout title="Research | Akito Nakano" description="研究活動 - 研究テーマ・論文">
	<main class="main">
		<BackToNav href="/" labelJa="TOP に戻る" labelEn="Back to TOP" position="top" />

		<h1 class="page-title">Research</h1>

		<section class="section">
			<h2 class="section-title">Topics</h2>
			<ProjectCardGrid type="research" items={researchEntries} />
		</section>

		<BackToNav href="/" labelJa="TOP に戻る" labelEn="Back to TOP" position="bottom" />
		<NavigationModal />
	</main>
</Layout>

<style>
	.main {
		max-width: 900px;
		margin: 0 auto;
		padding: 0 var(--space-xl);
	}

	.page-title {
		font-size: 2rem;
		font-weight: 700;
		margin-bottom: var(--space-2xl);
	}

	.section {
		margin-bottom: var(--space-2xl);
	}

	.section-title {
		font-size: 1.1rem;
		font-weight: 600;
		color: var(--color-text-muted);
		margin-bottom: var(--space-lg);
	}

	@media (max-width: 768px) {
		.main {
			padding: 0 var(--space-lg);
		}

		.page-title {
			font-size: 1.75rem;
		}
	}
</style>

---
/**
 * Research 詳細ページ
 * 研究テーマの詳細情報と関連論文を表示
 */
import ProjectDetailLayout from '@/components/layouts/ProjectDetailLayout.astro';
import { loadResearch, loadResearchById, loadPapersByResearchId } from '@/application';

export async function getStaticPaths() {
  const researches = await loadResearch();
  return researches.map((research) => ({
    params: { id: research.id },
  }));
}

const { id } = Astro.params;
const result = await loadResearchById(id);

if (!result) {
  return Astro.redirect('/');
}

const { research, Content } = result;
const papers = await loadPapersByResearchId(id);
---

<ProjectDetailLayout
  title={`${research.title.ja} | Research`}
  description={research.summary.ja}
  backLink={{
    href: '/research',
    labelJa: 'Research に戻る',
    labelEn: 'Back to Research',
  }}
  projectTitle={research.title}
  summary={research.summary}
  image={research.image}
  period={research.period}
>
  <Content />

  {papers.length > 0 && (
    <section class="papers-section" slot="extra">
      <h2 class="papers-header">
        <span class="lang-ja">関連論文</span>
        <span class="lang-en">Related Publications</span>
      </h2>
      <div class="papers-list">
        {papers.map((paper) => (
          <div class="paper-item">
            <div class="paper-content">
              <span class="paper-conference">{paper.conference}</span>
              {paper.award && (
                <span class="paper-award">
                  <span class="lang-ja">{paper.award.ja}</span>
                  <span class="lang-en">{paper.award.en || paper.award.ja}</span>
                </span>
              )}
              <h3 class="paper-title">
                <span class="lang-ja">{paper.title.ja}</span>
                <span class="lang-en">{paper.title.en || paper.title.ja}</span>
              </h3>
              <p class="paper-authors">
                <span class="lang-ja">{paper.authors.ja}</span>
                <span class="lang-en">{paper.authors.en || paper.authors.ja}</span>
              </p>
            </div>
            {paper.externalUrl && (
              <div class="paper-links">
                <a class="paper-link" href={paper.externalUrl} target="_blank" rel="noopener noreferrer">
                  <span class="lang-ja">論文を読む &rarr;</span>
                  <span class="lang-en">Read Paper &rarr;</span>
                </a>
              </div>
            )}
          </div>
        ))}
      </div>
    </section>
  )}
</ProjectDetailLayout>

<style>
  .papers-section {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-2xl);
    margin-top: var(--space-2xl);
  }

  .papers-header {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
  }

  .papers-list {
    display: flex;
    flex-direction: column;
  }

  .paper-item {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-lg);
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .paper-item:first-child {
    padding-top: 0;
  }

  .paper-item:last-child {
    border-bottom: none;
  }

  .paper-content {
    flex: 1;
    min-width: 0;
  }

  .paper-conference {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    background: var(--color-accent-soft);
    padding: 0.2em 0.6em;
    border-radius: 3px;
    letter-spacing: 0.02em;
    margin-right: var(--space-sm);
  }

  .paper-award {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-award);
    background: var(--color-award-soft);
    padding: 0.2em 0.6em;
    border-radius: 3px;
  }

  .paper-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.6;
    margin-top: var(--space-sm);
    margin-bottom: var(--space-xs);
    color: var(--color-text);
  }

  .paper-authors {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .paper-links {
    flex-shrink: 0;
  }

  .paper-link {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: var(--color-border);
    transition: color var(--transition-base), text-decoration-color var(--transition-base);
    white-space: nowrap;
  }

  .paper-link:hover {
    color: var(--color-text);
    text-decoration-color: var(--color-text);
  }

  @media (max-width: 768px) {
    .paper-item {
      flex-direction: column;
      gap: var(--space-md);
    }
  }
</style>
